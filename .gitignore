# The torchtitan fork is registered as a git submodule (see .gitmodules).
# A submodule is a gitlink pointing at a specific commit in
# QIU023/torchtitan, NOT a nested working copy, so history on both sides
# stays intact. Do not re-ignore 'torchtitan/' — git would then refuse to
# add or update the gitlink.

# Kimi's reference implementation is a separate upstream repo; don't vendor it.
# Clone alongside this workspace if needed.
Attention-Residuals/

# Claude Code project cache (hooks, memory, sessions). Not useful to others.
.claude/

# Oh-My-ClaudeCode (OMC) project state. We commit .omc/skills/ and the
# RELEASE_RULE cache (both are recipe content, see SETUP_OMC.md); everything
# else under .omc/ is runtime scratch — per-session plans, in-flight state,
# local caches.
.omc/*
!.omc/skills/
!.omc/RELEASE_RULE.md

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/

# Run artifacts we do NOT want in git history
phase2/runs/**/tb/
phase2/runs/**/checkpoint/
phase2/runs/**/comm_traces/
phase2/runs/**/DONE
phase2/runs/**/GIT_SHA

phase3/runs/**/tb/
phase3/runs/**/checkpoint/
phase3/runs/**/comm_traces/

phase4/runs/**/tb/
phase4/runs/**/checkpoint/
phase4/runs/**/comm_traces/

phase5_distillation_deprecated/runs/**/tb/
phase5_distillation_deprecated/runs/**/checkpoint/
phase5_distillation_deprecated/runs/**/comm_traces/
phase5_distillation_deprecated/miniplm/runs/**/tb/
phase5_distillation_deprecated/miniplm/runs/**/checkpoint/
phase5_distillation_deprecated/miniplm/runs/**/comm_traces/

phase5/runs/**/checkpoint/
phase5/runs/**/comm_traces/
# Phase 7 NCCL traces (~10-200MB per dir, 18+ dirs total) — produced by
# launch_8gpu_mm.sh's TRACE_TIER=tier_{a,b,c}; the parsed CSV summaries
# (collective_summary.csv) are kept; raw nccl-rank-*.log files are not.
phase5/runs/**/tier_a_trace/nccl-rank-*.log
phase5/runs/**/tier_b_trace/nccl-rank-*.log
phase5/runs/**/tier_c_trace/nccl-rank-*.log
phase5/runs/**/tier_a_trace/nsys-*
phase5/runs/**/tier_b_trace/nsys-*
phase5/runs/**/tier_c_trace/nsys-*
# collective_summary.csv can be 200k-800k rows (one row per NCCL collective
# call across all ranks × all steps). Reproducible from raw logs via
# phase7/extract_collectives.py; histograms are stored in pattern_catalog.md.
phase5/runs/**/tier_a_trace/collective_summary.csv
phase5/runs/**/tier_b_trace/collective_summary.csv
phase5/runs/**/tier_c_trace/collective_summary.csv
# flows.csv: per-pair P2P decomposition produced by phase7/expand_to_flows.py;
# can be 200MB+ for tier_b on large LBS runs. Recreate via the same script
# from collective_summary.csv. The aggregated ixia_config.json (~32K) IS
# committed as the small canonical artifact.
phase5/runs/**/tier_a_trace/flows.csv
phase5/runs/**/tier_b_trace/flows.csv
phase5/runs/**/tier_c_trace/flows.csv
# csv.gz are KEPT — they preserve raw aggregated trace data beyond the
# tiny ixia_config.json. Files larger than GitHub's 100 MB blob ceiling
# (v11 5000-step trace produces ~210 MB + ~110 MB) are tracked via
# git LFS — see .gitattributes.

# Phase 10 DCP -> HF safetensors conversion output (~2.6 GB; fully
# reproducible via phase10/dcp_to_hf_kimi_attn_res.py from the source
# DCP ckpt — never needs to live in git).
phase10/hf_ckpt_*/
# phase5/runs/**/tb/ intentionally tracked: TB files are <1MB each and are
# the only loss-curve provenance for phase 6 runs (network bandwidth on
# this box can't push ckpts off, so tb is the next best archive).

# Keep: train.log tails (for provenance) and comparison.png (the money shot).
# Explicit un-ignore:
!phase2/runs/**/comparison.png
!phase2/runs/**/train.log
!phase3/runs/**/train.log
!phase3/runs/**/comparison.png
!phase4/runs/**/train.log
!phase4/runs/**/comparison.png
!phase5_distillation_deprecated/runs/**/eval.log
!phase5_distillation_deprecated/runs/**/train.log
!phase5_distillation_deprecated/miniplm/runs/**/eval.log
!phase5_distillation_deprecated/miniplm/runs/**/train.log
!phase5/runs/**/eval.log
!phase5/runs/**/train.log

# Backup archives — ignored by default. phase7/archive/ holds the
# committed trace tarballs (NCCL logs + recipe + tb) for cluster
# traffic replay; explicitly un-ignore that path.
*.tar.gz
*.tgz
!phase7/archive/*.tar.gz

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
phase5_distillation_deprecated/miniplm/scored/
