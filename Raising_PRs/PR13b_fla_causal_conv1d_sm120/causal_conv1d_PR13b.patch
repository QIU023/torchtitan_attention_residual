     ],
-    key=['D', 'W', 'NB'],
+    # PR13b: drop phantom "NB" from the autotuner key (bwd kernel). Same root
+    # cause as the fwd kernel above: NB is a constexpr never used in the body and
+    # changes with T, forcing re-autotuning per new T range that crashes the
